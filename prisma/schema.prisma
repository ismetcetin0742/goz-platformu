generator client {
  provider      = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    Int     @id @default(autoincrement())
  name          String?
  email         String    @unique
  image         String?
  password      String?
  role          String    @default("USER")
  isBanned      Boolean   @default(false)
  banReason     String?   // Yasaklanma nedenini saklamak için
  emailVerified DateTime? // Mail doğrulandığında bu tarih dolacak
  verifyToken String? @unique @db.VarChar(255) // Maildeki linke koyacağımız gizli kod
  managedOpticians OpticianManager[] // Kullanıcının yönettiği mağazalar
  posts         Post[]
  isActive  Boolean  @default(true)
   createdAt     DateTime @default(now())
  
}
model Settings {
  id                Int      @id @default(1) // Sadece 1 satır olacak
  mailService       String   @default("SMTP") // "SMTP" veya "RESEND"
  smtpHost          String?
  smtpPort          Int?     @default(587)
  smtpUser          String?
  smtpPass          String?
  resendApiKey      String?
  fromEmail         String   @default("noreply@gozplatformu.com")
  updatedAt         DateTime @updatedAt
}
enum PostStatus {
  PENDING   // Onay Bekliyor
  APPROVED  // Onaylandı (Yayında)
  REJECTED  // Reddedildi
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String
  content     String     @db.Text
  imageUrl    String?
  category    String     @default("Göz Sağlığı")
  views       Int        @default(0)
  status      PostStatus @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  author      User       @relation(fields: [authorId], references: [id])
  authorId    Int
}

model Optician {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  phone     String?
  latitude  Float
  longitude Float
  hasSunGlasses   Boolean  @default(false) // Güneş gözlüğü yetkisi
  hasPrescription Boolean  @default(false) // Numaralı gözlük yetkisi
  managers  OpticianManager[] // Mağazayı yöneten kullanıcılar
  products  Product[]         // Mağazanın ürünleri
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OpticianManager {
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  optician   Optician @relation(fields: [opticianId], references: [id], onDelete: Cascade)
  opticianId Int

  @@id([userId, opticianId])
}

enum ProductCategory {
  SUNGLASSES
  PRESCRIPTION
}

model Product {
  id          Int             @id @default(autoincrement())
  name        String
  brand       String
  description String          @db.Text
  price       Decimal         @db.Decimal(10, 2)
  imageUrl    String?
  category    ProductCategory
  optician    Optician        @relation(fields: [opticianId], references: [id], onDelete: Cascade)
  opticianId  Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}